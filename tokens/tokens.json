{
  "primitives": {
    "purple": {
      "900": { "value": "#3B1A8A", "$type": "color", "description": "Purple darkest" },
      "800": { "value": "#4E22B0", "$type": "color" },
      "700": { "value": "#6D28D9", "$type": "color", "description": "Purple Heart — main brand" },
      "600": { "value": "#7C35EB", "$type": "color", "description": "Hover / dark mode" },
      "100": { "value": "#F0E9FB", "$type": "color", "description": "Purple Light — subtle bg" },
      "50":  { "value": "#FAF7FF", "$type": "color" }
    },
    "neutral": {
      "0":   { "value": "#FFFFFF", "$type": "color", "description": "Pure White" },
      "50":  { "value": "#FCFCFC", "$type": "color", "description": "Alabaster" },
      "100": { "value": "#F7F8FA", "$type": "color", "description": "Shatlevka — page bg" },
      "200": { "value": "#EBEBEB", "$type": "color", "description": "Warm Gray — borders" },
      "400": { "value": "#AEAEAE", "$type": "color", "description": "Soft Gray — disabled" },
      "600": { "value": "#717182", "$type": "color", "description": "Storm Gray — secondary text" },
      "800": { "value": "#1E1E1E", "$type": "color", "description": "PopUp Gray" },
      "950": { "value": "#0A0A0A", "$type": "color", "description": "Cod Gray — primary text" }
    },
    "green": {
      "700": { "value": "#009689", "$type": "color", "description": "Persian Green — success" },
      "100": { "value": "#DCFCE7", "$type": "color", "description": "Persian Light — success bg" }
    },
    "orange": {
      "500": { "value": "#FE9A00", "$type": "color", "description": "California — warning" },
      "100": { "value": "#FFEDD4", "$type": "color", "description": "California Light — warning bg" }
    },
    "red": {
      "600": { "value": "#F54900", "$type": "color", "description": "Vermilion — error" },
      "100": { "value": "#FFDDDB", "$type": "color", "description": "Vermilion Light — error bg" }
    }
  },

  "semantic": {
    "color": {
      "brand": {
        "default": { "value": "{primitives.purple.700}", "$type": "color" },
        "hover":   { "value": "{primitives.purple.600}", "$type": "color" },
        "subtle":  { "value": "{primitives.purple.100}", "$type": "color" }
      },
      "bg": {
        "page":    { "value": "{primitives.neutral.100}", "$type": "color" },
        "surface": { "value": "{primitives.neutral.0}",   "$type": "color" },
        "overlay": { "value": "{primitives.neutral.800}", "$type": "color" }
      },
      "text": {
        "primary":   { "value": "{primitives.neutral.950}", "$type": "color" },
        "secondary": { "value": "{primitives.neutral.600}", "$type": "color" },
        "disabled":  { "value": "{primitives.neutral.400}", "$type": "color" },
        "inverse":   { "value": "{primitives.neutral.50}",  "$type": "color" },
        "brand":     { "value": "{primitives.purple.700}",  "$type": "color" }
      },
      "border": {
        "default": { "value": "{primitives.neutral.200}", "$type": "color" },
        "brand":   { "value": "{primitives.purple.700}",  "$type": "color" },
        "focus":   { "value": "{primitives.purple.600}",  "$type": "color" }
      },
      "status": {
        "success":        { "value": "{primitives.green.700}",  "$type": "color" },
        "success-subtle": { "value": "{primitives.green.100}",  "$type": "color" },
        "warning":        { "value": "{primitives.orange.500}", "$type": "color" },
        "warning-subtle": { "value": "{primitives.orange.100}", "$type": "color" },
        "error":          { "value": "{primitives.red.600}",    "$type": "color" },
        "error-subtle":   { "value": "{primitives.red.100}",    "$type": "color" }
      }
    }
  },

  "component": {
    "button": {
      "primary": {
        "bg":       { "value": "{semantic.color.brand.default}", "$type": "color" },
        "bg-hover": { "value": "{semantic.color.brand.hover}",   "$type": "color" },
        "text":     { "value": "{semantic.color.text.inverse}",  "$type": "color" }
      },
      "secondary": {
        "bg":            { "value": "{semantic.color.bg.surface}",    "$type": "color" },
        "bg-hover":      { "value": "{semantic.color.brand.subtle}",  "$type": "color" },
        "text":          { "value": "{semantic.color.text.brand}",    "$type": "color" },
        "border":        { "value": "{semantic.color.border.default}","$type": "color" },
        "border-hover":  { "value": "{semantic.color.border.brand}",  "$type": "color" }
      },
      "ghost": {
        "bg":       { "value": "{semantic.color.bg.page}",       "$type": "color" },
        "bg-hover": { "value": "{semantic.color.brand.subtle}",  "$type": "color" },
        "text":     { "value": "{semantic.color.text.brand}",    "$type": "color" }
      },
      "disabled": {
        "text":   { "value": "{semantic.color.text.disabled}",   "$type": "color" },
        "border": { "value": "{semantic.color.border.default}",  "$type": "color" }
      }
    }
  },

  "spacing": {
    "1":  { "value": "4",   "$type": "dimension" },
    "2":  { "value": "8",   "$type": "dimension" },
    "3":  { "value": "12",  "$type": "dimension" },
    "4":  { "value": "16",  "$type": "dimension" },
    "5":  { "value": "20",  "$type": "dimension" },
    "6":  { "value": "24",  "$type": "dimension" },
    "8":  { "value": "32",  "$type": "dimension" },
    "10": { "value": "40",  "$type": "dimension" },
    "12": { "value": "48",  "$type": "dimension" }
  },

  "radius": {
    "sm":   { "value": "4",   "$type": "dimension" },
    "md":   { "value": "8",   "$type": "dimension" },
    "lg":   { "value": "12",  "$type": "dimension" },
    "xl":   { "value": "16",  "$type": "dimension" },
    "full": { "value": "999", "$type": "dimension" }
  },

  "$metadata": {
    "tokenSetOrder": ["primitives", "semantic", "component", "spacing", "radius"]
  }
}
